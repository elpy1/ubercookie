# Managed by Ansible.
log_format cloudflare_main '$remote_addr - $remote_user [$time_local] "$request" '
                           '$status $body_bytes_sent "$http_referer" "$http_user_agent" '
                           'cf_ray="$http_cf_ray" edge="$realip_remote_addr" '
